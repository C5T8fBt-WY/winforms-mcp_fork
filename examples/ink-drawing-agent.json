{
  "name": "Pen-Based Drawing Agent",
  "description": "Demonstrates pen/stylus input for InkCanvas applications",
  "prerequisites": {
    "app": "InkCanvas-enabled application",
    "coordinates": "Window-relative mode recommended",
    "permissions": "Admin privileges (handled by sandbox)"
  },
  "examples": [
    {
      "name": "draw_signature",
      "description": "Draw a simple signature with pressure variation",
      "script": {
        "steps": [
          {
            "id": "launch",
            "tool": "launch_app",
            "args": {
              "path": "C:\\TestApps\\InkDemo.exe"
            },
            "delay_after_ms": 2000
          },
          {
            "id": "wait_canvas",
            "tool": "wait_for_element",
            "args": {
              "automationId": "inkCanvas",
              "timeoutMs": 5000
            }
          },
          {
            "id": "stroke1",
            "tool": "drag",
            "args": {
              "path": [
                { "x": 50, "y": 150, "pressure": 400 },
                { "x": 100, "y": 100, "pressure": 400 }
              ],
              "input": "pen",
              "duration_ms": 500,
              "windowTitle": "Ink Demo"
            },
            "delay_after_ms": 50
          },
          {
            "id": "stroke2",
            "tool": "drag",
            "args": {
              "path": [
                { "x": 100, "y": 100, "pressure": 600 },
                { "x": 150, "y": 150, "pressure": 600 }
              ],
              "input": "pen",
              "duration_ms": 500,
              "windowTitle": "Ink Demo"
            },
            "delay_after_ms": 50
          },
          {
            "id": "stroke3",
            "tool": "drag",
            "args": {
              "path": [
                { "x": 150, "y": 150, "pressure": 300 },
                { "x": 200, "y": 100, "pressure": 300 }
              ],
              "input": "pen",
              "duration_ms": 500,
              "windowTitle": "Ink Demo"
            },
            "delay_after_ms": 50
          },
          {
            "id": "screenshot",
            "tool": "take_screenshot",
            "args": {
              "windowTitle": "Ink Demo",
              "outputPath": "C:\\Output\\signature.png"
            }
          }
        ],
        "options": {
          "stop_on_error": true,
          "timeout_ms": 30000
        }
      }
    },
    {
      "name": "draw_rectangle",
      "description": "Draw a rectangle with consistent pressure",
      "script": {
        "steps": [
          {
            "tool": "drag",
            "args": {
              "path": [
                { "x": 100, "y": 100, "pressure": 512 },
                { "x": 300, "y": 100, "pressure": 512 },
                { "x": 300, "y": 200, "pressure": 512 },
                { "x": 100, "y": 200, "pressure": 512 },
                { "x": 100, "y": 100, "pressure": 512 }
              ],
              "input": "pen",
              "duration_ms": 2000,
              "windowTitle": "Ink Demo"
            }
          }
        ],
        "options": {
          "default_delay_ms": 30
        }
      }
    },
    {
      "name": "erase_and_redraw",
      "description": "Demonstrate eraser mode",
      "script": {
        "steps": [
          {
            "id": "draw",
            "tool": "drag",
            "args": {
              "path": [
                { "x": 100, "y": 150 },
                { "x": 300, "y": 150 }
              ],
              "input": "pen",
              "pressure": 512,
              "eraser": false,
              "duration_ms": 500,
              "windowTitle": "Ink Demo"
            },
            "delay_after_ms": 500
          },
          {
            "id": "erase",
            "tool": "drag",
            "args": {
              "path": [
                { "x": 150, "y": 100 },
                { "x": 250, "y": 200 }
              ],
              "input": "pen",
              "pressure": 512,
              "eraser": true,
              "duration_ms": 500,
              "windowTitle": "Ink Demo"
            },
            "delay_after_ms": 500
          },
          {
            "id": "redraw",
            "tool": "drag",
            "args": {
              "path": [
                { "x": 175, "y": 125 },
                { "x": 225, "y": 175 }
              ],
              "input": "pen",
              "pressure": 768,
              "eraser": false,
              "duration_ms": 500,
              "windowTitle": "Ink Demo"
            }
          }
        ]
      }
    },
    {
      "name": "pinch_zoom_canvas",
      "description": "Zoom in on the canvas using pinch gesture",
      "script": {
        "steps": [
          {
            "id": "zoom_in",
            "tool": "gesture",
            "args": {
              "type": "pinch",
              "center": { "x": 200, "y": 200 },
              "start_distance": 50,
              "end_distance": 150,
              "duration_ms": 1000,
              "windowTitle": "Ink Demo"
            },
            "delay_after_ms": 500
          },
          {
            "id": "verify_zoom",
            "tool": "take_screenshot",
            "args": {
              "windowTitle": "Ink Demo",
              "outputPath": "C:\\Output\\zoomed.png"
            }
          },
          {
            "id": "zoom_out",
            "tool": "gesture",
            "args": {
              "type": "pinch",
              "center": { "x": 200, "y": 200 },
              "start_distance": 150,
              "end_distance": 50,
              "duration_ms": 1000,
              "windowTitle": "Ink Demo"
            }
          }
        ]
      }
    }
  ],
  "pressure_guide": {
    "0": "Hovering (not touching surface)",
    "256": "Light touch - thin strokes",
    "512": "Normal pressure - default",
    "768": "Firm pressure - thick strokes",
    "1024": "Maximum pressure - thickest strokes"
  },
  "tips": [
    "Use window-relative coordinates (windowTitle parameter) for consistent positioning",
    "Use 'drag' tool with 'input': 'pen' for strokes",
    "Add delays between strokes if ink rendering is slow",
    "Use eraser=true to erase ink instead of drawing",
    "Vary pressure along strokes for calligraphy effects",
    "Take screenshots to verify ink was captured correctly"
  ],
  "patterns_demonstrated": [
    "Pen stroke with pressure variation",
    "Multi-stroke drawing sequences",
    "Eraser mode for corrections",
    "Pinch zoom gesture",
    "Screenshot verification"
  ]
}