<Configuration>
  <VGpu>Disable</VGpu>
  <Networking>Default</Networking>
  <ProtectedClient>Disable</ProtectedClient>
  <MappedFolders>
    <!-- MCP Server binaries (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\Server</HostFolder>
      <SandboxFolder>C:\Server</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Test Application binaries (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\App</HostFolder>
      <SandboxFolder>C:\App</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Pre-downloaded .NET runtime (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\DotNet</HostFolder>
      <SandboxFolder>C:\DotNet</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Shared communication folder (read-write) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\Shared</HostFolder>
      <SandboxFolder>C:\Shared</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
    <!-- Source code for in-sandbox compilation (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\Source</HostFolder>
      <SandboxFolder>C:\Source</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <!-- Bootstrap with TCP mode, LazyStart, code coverage, and watchdog restart loop -->
    <!-- Watchdog kills orphaned server/app processes before restarting bootstrap -->
    <Command>powershell -ExecutionPolicy Bypass -NoExit -Command "reg add 'HKLM\SYSTEM\CurrentControlSet\Control\CI\Policy' /v VerifiedAndReputablePolicyState /t REG_DWORD /d 0 /f; $env:DOTNET_ROOT = 'C:\DotNet'; $env:PATH = 'C:\DotNet;' + $env:PATH; while ($true) { Write-Host '[Watchdog] Killing orphaned processes...'; Get-Process -Name 'dotnet*','Rhombus*','MagpieCad*','TestApp*' -ErrorAction SilentlyContinue | Where-Object { $_.Id -ne $PID } | Stop-Process -Force -ErrorAction SilentlyContinue; Start-Sleep 2; Write-Host '[Watchdog] Starting bootstrap...'; try { &amp; 'C:\Server\bootstrap.ps1' -EnableTcp -TcpPort 9999 -E2EPort 9998 -LazyStart -EnableCoverage } catch { Write-Host \"[Watchdog] Bootstrap threw: $_\" }; Write-Host '[Watchdog] Bootstrap exited, restarting in 3s...'; Start-Sleep 3 }"</Command>
  </LogonCommand>
</Configuration>
