<Configuration>
  <VGpu>Disable</VGpu>
  <Networking>Default</Networking>
  <ProtectedClient>Disable</ProtectedClient>
  <MappedFolders>
    <!-- MCP Server binaries (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\Server</HostFolder>
      <SandboxFolder>C:\Server</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Test Application binaries (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\App</HostFolder>
      <SandboxFolder>C:\App</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Pre-downloaded .NET runtime (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\DotNet</HostFolder>
      <SandboxFolder>C:\DotNet</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Shared communication folder (read-write) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\Shared</HostFolder>
      <SandboxFolder>C:\Shared</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
    <!-- Source code for in-sandbox compilation (read-only) -->
    <MappedFolder>
      <HostFolder>C:\WinFormsMcpSandboxWorkspace\Source</HostFolder>
      <SandboxFolder>C:\Source</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <!-- Bootstrap with TCP mode, LazyStart, code coverage, and watchdog restart loop -->
    <!-- Watchdog kills orphaned server/app processes before restarting bootstrap -->
    <!-- Unblock-File strips Mark of the Web from mapped folder files -->
    <Command>powershell -ExecutionPolicy Bypass -NoExit -Command "Write-Host '[Init] Configuring Zone Trust for mapped folders...'; reg add 'HKCU\Software\Microsoft\Windows\CurrentVersion\Internet Settings\ZoneMap\ProtocolDefaults' /v file /t REG_DWORD /d 1 /f | Out-Null; Write-Host '[Init] Stripping Mark of the Web from mapped folders...'; Get-ChildItem -Path 'C:\Server','C:\App','C:\DotNet','C:\Source','C:\Shared' -Recurse -ErrorAction SilentlyContinue | Unblock-File -ErrorAction SilentlyContinue; Write-Host '[Init] Disabling SmartScreen policies...'; Set-MpPreference -SmartScreenForExplorer Disabled -ErrorAction SilentlyContinue; New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\System' -Force -ErrorAction SilentlyContinue | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\System' -Name 'EnableSmartScreen' -Value 0 -Force -ErrorAction SilentlyContinue; reg add 'HKLM\SYSTEM\CurrentControlSet\Control\CI\Policy' /v VerifiedAndReputablePolicyState /t REG_DWORD /d 0 /f 2>&amp;1 | Out-Null; Write-Host '--- DIAGNOSTIC PANIC BUTTON ---' -ForegroundColor Yellow; Write-Host 'If apps block, run: Get-WinEvent -LogName \"Microsoft-Windows-CodeIntegrity/Operational\" | Where-Object { $_.Id -eq 3076 -or $_.Id -eq 3077 }' -ForegroundColor Yellow; $env:DOTNET_ROOT = 'C:\DotNet'; $env:PATH = 'C:\DotNet;' + $env:PATH; while ($true) { Write-Host '[Watchdog] Killing orphaned processes...'; Get-Process -Name 'dotnet*','Rhombus*','MagpieCad*','TestApp*' -ErrorAction SilentlyContinue | Where-Object { $_.Id -ne $PID } | Stop-Process -Force -ErrorAction SilentlyContinue; Start-Sleep 2; Write-Host '[Watchdog] Starting bootstrap...'; try { &amp; 'C:\Server\bootstrap.ps1' -EnableTcp -TcpPort 9999 -E2EPort 9998 -LazyStart } catch { Write-Host \"[Watchdog] Bootstrap threw: $_\" }; Write-Host '[Watchdog] Bootstrap exited, restarting in 3s...'; Start-Sleep 3 }"</Command>
  </LogonCommand>
</Configuration>
