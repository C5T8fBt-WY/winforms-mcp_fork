<Configuration>
  <VGpu>Disable</VGpu>
  <Networking>Disable</Networking>
  <MappedFolders>
    <!-- Client binary (read-only) -->
    <MappedFolder>
      <HostFolder>C:\TransportTest\SharedClient</HostFolder>
      <SandboxFolder>C:\Client</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Shared communication folder (read-write for both host and sandbox) -->
    <MappedFolder>
      <HostFolder>C:\TransportTest\Shared</HostFolder>
      <SandboxFolder>C:\Shared</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>C:\Client\SharedFolderClient.exe</Command>
  </LogonCommand>
</Configuration>
