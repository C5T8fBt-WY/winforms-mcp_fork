<Configuration>
  <VGpu>Disable</VGpu>
  <Networking>Disable</Networking>
  <MappedFolders>
    <!-- Client test binary (read-only) -->
    <MappedFolder>
      <HostFolder>C:\TransportTest\Client</HostFolder>
      <SandboxFolder>C:\Client</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!-- Output folder for results (writable) -->
    <MappedFolder>
      <HostFolder>C:\TransportTest\Output</HostFolder>
      <SandboxFolder>C:\Output</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>C:\Client\NamedPipeClientTest.exe</Command>
  </LogonCommand>
</Configuration>
